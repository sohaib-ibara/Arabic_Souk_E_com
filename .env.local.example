# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in your values.
# The storefront runs WITHOUT these (it falls back to the bundled sample
# catalogue), but set them to serve the catalogue from your Supabase project.
# ---------------------------------------------------------------------------

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Absolute site URL — used for canonical links, sitemap.xml and Open Graph tags.
# Use your production domain when deploying (e.g. https://lumiere.bh).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
