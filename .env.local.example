# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in your values.
# The storefront runs WITHOUT these (it falls back to the bundled sample
# catalogue), but set them to serve the catalogue from your Supabase project.
# ---------------------------------------------------------------------------

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Absolute site URL — used for canonical links, sitemap.xml and Open Graph tags.
# Use your production domain when deploying (e.g. https://arabicsouk.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Noon import pipeline — IMPORT SCRIPTS ONLY (feature/noon-import branch).
# Not used by the storefront. See docs/NOON_IMPORT.md, and read its rights notice.
# The service-role key bypasses RLS — keep it server-side only, NEVER prefix it
# with NEXT_PUBLIC_, and never commit real values.
# ---------------------------------------------------------------------------
# FIRECRAWL_API_KEY=fc-...
# ANTHROPIC_API_KEY=sk-ant-...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# TARGET_URL=https://www.noon.com/saudi-en/noon-premium-beauty/
# MAX_PRODUCTS=20
# ANTHROPIC_MODEL=claude-opus-4-8
# PRICE_CONVERSION_RATE=0.1
